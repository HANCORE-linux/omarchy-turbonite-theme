            "terminal.ansi.red": "#8f6969",
            "terminal.ansi.green": "#6E6A64",
            "terminal.ansi.yellow": "#4e4747",
            "terminal.ansi.blue": "#92958a",
            "terminal.ansi.magenta": "#747474",
            "terminal.ansi.cyan": "#868686",
            "terminal.ansi.white": "#b9b9b9",
